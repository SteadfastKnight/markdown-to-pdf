<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>com.steadfastknight</groupId>
  <artifactId>md2pdf</artifactId>
  <version>1.0.0</version>
  <packaging>jar</packaging>
  <name>MD-to-PDF Booklet</name>
  <description>Markdown -> print-ready booklet PDF (A6 4-up / A5 2-up / A4 1-up on A4)</description>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <maven.compiler.release>21</maven.compiler.release>

    <javafx.version>21.0.4</javafx.version>
    <!-- JavaFX native classifier; overridden by the os profiles below. -->
    <javafx.platform>win</javafx.platform>

    <flexmark.version>0.64.8</flexmark.version>
    <openhtmltopdf.version>1.0.10</openhtmltopdf.version>
    <pdfbox.version>2.0.31</pdfbox.version>

    <main.class>com.steadfastknight.md2pdf.Launcher</main.class>
    <app.name>MD-to-PDF Booklet</app.name>
  </properties>

  <dependencies>
    <!-- Markdown -> HTML -->
    <dependency>
      <groupId>com.vladsch.flexmark</groupId>
      <artifactId>flexmark-all</artifactId>
      <version>${flexmark.version}</version>
    </dependency>

    <!-- HTML+CSS -> PDF (pulls in PDFBox 2.x transitively) -->
    <dependency>
      <groupId>com.openhtmltopdf</groupId>
      <artifactId>openhtmltopdf-pdfbox</artifactId>
      <version>${openhtmltopdf.version}</version>
    </dependency>

    <!-- PDFBox: pinned 2.0.x, used directly for N-up imposition (LayerUtility) -->
    <dependency>
      <groupId>org.apache.pdfbox</groupId>
      <artifactId>pdfbox</artifactId>
      <version>${pdfbox.version}</version>
    </dependency>

    <!-- JavaFX UI. Bundled (with native classifier) into the shaded jar so the
         non-Application Launcher can run it from the classpath; jpackage then
         only needs a base JRE, no separate JavaFX module path. -->
    <dependency>
      <groupId>org.openjfx</groupId>
      <artifactId>javafx-base</artifactId>
      <version>${javafx.version}</version>
      <classifier>${javafx.platform}</classifier>
    </dependency>
    <dependency>
      <groupId>org.openjfx</groupId>
      <artifactId>javafx-graphics</artifactId>
      <version>${javafx.version}</version>
      <classifier>${javafx.platform}</classifier>
    </dependency>
    <dependency>
      <groupId>org.openjfx</groupId>
      <artifactId>javafx-controls</artifactId>
      <version>${javafx.version}</version>
      <classifier>${javafx.platform}</classifier>
    </dependency>
  </dependencies>

  <build>
    <finalName>md2pdf</finalName>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.13.0</version>
      </plugin>

      <!-- Fat jar: app + all deps (incl. JavaFX native classifier jars). -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.6.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals><goal>shade</goal></goals>
            <configuration>
              <createDependencyReducedPom>false</createDependencyReducedPom>
              <shadedArtifactAttached>false</shadedArtifactAttached>
              <!-- Clean staging dir holding only the fat jar, for the jpackage input. -->
              <outputFile>${project.build.directory}/app/md2pdf.jar</outputFile>
              <transformers>
                <transformer implementation="org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">
                  <mainClass>${main.class}</mainClass>
                </transformer>
                <transformer implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
              </transformers>
              <filters>
                <filter>
                  <artifact>*:*</artifact>
                  <excludes>
                    <exclude>META-INF/*.SF</exclude>
                    <exclude>META-INF/*.DSA</exclude>
                    <exclude>META-INF/*.RSA</exclude>
                    <exclude>module-info.class</exclude>
                  </excludes>
                </filter>
              </filters>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>

  <profiles>
    <!-- JavaFX native classifier per build host. -->
    <profile>
      <id>jfx-win</id>
      <activation><os><family>windows</family></os></activation>
      <properties><javafx.platform>win</javafx.platform></properties>
    </profile>
    <profile>
      <id>jfx-linux</id>
      <activation><os><family>unix</family><name>linux</name></os></activation>
      <properties><javafx.platform>linux</javafx.platform></properties>
    </profile>
    <profile>
      <id>jfx-mac</id>
      <activation><os><family>mac</family><arch>x86_64</arch></os></activation>
      <properties><javafx.platform>mac</javafx.platform></properties>
    </profile>
    <profile>
      <id>jfx-mac-aarch64</id>
      <activation><os><family>mac</family><arch>aarch64</arch></os></activation>
      <properties><javafx.platform>mac-aarch64</javafx.platform></properties>
    </profile>

    <!-- mvn -Pdist package  ->  self-contained app-image under dist/ -->
    <profile>
      <id>dist</id>
      <build>
        <plugins>
          <plugin>
            <groupId>org.codehaus.mojo</groupId>
            <artifactId>exec-maven-plugin</artifactId>
            <version>3.5.0</version>
            <executions>
              <execution>
                <id>jpackage-app-image</id>
                <phase>package</phase>
                <goals><goal>exec</goal></goals>
                <configuration>
                  <executable>jpackage</executable>
                  <arguments>
                    <argument>--type</argument><argument>app-image</argument>
                    <argument>--name</argument><argument>${app.name}</argument>
                    <argument>--app-version</argument><argument>${project.version}</argument>
                    <argument>--icon</argument><argument>${project.basedir}/src/main/resources/icon/app.ico</argument>
                    <argument>--input</argument><argument>${project.build.directory}/app</argument>
                    <argument>--main-jar</argument><argument>md2pdf.jar</argument>
                    <argument>--main-class</argument><argument>${main.class}</argument>
                    <argument>--dest</argument><argument>${project.build.directory}/dist</argument>
                    <!-- Trim the bundled runtime to the JDK modules we actually use. -->
                    <argument>--add-modules</argument>
                    <argument>java.base,java.desktop,java.xml,java.logging,java.naming,java.management,jdk.unsupported,jdk.zipfs</argument>
                    <argument>--jlink-options</argument>
                    <argument>--strip-debug --no-man-pages --no-header-files --compress=2</argument>
                  </arguments>
                </configuration>
              </execution>
            </executions>
          </plugin>
        </plugins>
      </build>
    </profile>
  </profiles>
</project>
