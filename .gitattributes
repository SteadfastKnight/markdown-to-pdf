# Normalize text to LF in the repo; let Windows check out CRLF where natural.
* text=auto

# Shell scripts and the Maven wrapper must stay LF or they break on *nix.
mvnw          text eol=lf
*.sh          text eol=lf

# Windows batch stays CRLF.
mvnw.cmd      text eol=crlf
*.cmd         text eol=crlf

# Binaries: never touch.
*.ttf  binary
*.pdf  binary
*.exe  binary
*.jar  binary
*.png  binary
